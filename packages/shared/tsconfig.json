{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "rootDir": "src",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
