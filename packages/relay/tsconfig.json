{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "jsx": "react-jsx",
    "jsxImportSource": "@kitajs/html",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src"]
}
