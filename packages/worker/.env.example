# --- Network environment ---
# Default: testnet. Set to mainnet for production.
NETWORK_ENV=testnet

# --- Facilitator wallet addresses (required, always) ---
FACILITATOR_BASE=0x...
FACILITATOR_SOLANA=...
FACILITATOR_STELLAR=G...

# --- Facilitator signing keys (worker-only, required) ---
FACILITATOR_PRIVATE_KEY_BASE=0x...
FACILITATOR_PRIVATE_KEY_SOLANA=base64-encoded-keypair
FACILITATOR_PRIVATE_KEY_STELLAR=S...

# --- RPC URLs ---
# Required in mainnet mode (no sensible default):
BASE_RPC_URL=
SOLANA_RPC_URL=
STELLAR_RPC_URL=
# Optional in testnet mode (public defaults embedded):
BASE_SEPOLIA_RPC_URL=
SOLANA_DEVNET_RPC_URL=
STELLAR_TESTNET_RPC_URL=

# --- Infrastructure ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fourzerotwomd
REDIS_URL=redis://localhost:6379
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=402md-settlement

# --- Tracing ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
