# --- Network environment ---
# Default: testnet. Set to mainnet for production.
NETWORK_ENV=testnet

# --- Facilitator wallet addresses (required, always) ---
# All EVM chains share the same 0x... address (same private key → same EIP-155 address)
FACILITATOR_BASE=0x...
FACILITATOR_ETHEREUM=0x...
FACILITATOR_OPTIMISM=0x...
FACILITATOR_ARBITRUM=0x...
FACILITATOR_LINEA=0x...
FACILITATOR_UNICHAIN=0x...
FACILITATOR_WORLDCHAIN=0x...
FACILITATOR_SOLANA=...
FACILITATOR_STELLAR=G...

# --- Facilitator signing keys (worker-only, required) ---
# One key per chain family — the EVM key is reused across all 7 EVM chains
FACILITATOR_PRIVATE_KEY_EVM=0x...
FACILITATOR_PRIVATE_KEY_SOLANA=base64-encoded-keypair
FACILITATOR_PRIVATE_KEY_STELLAR=S...

# --- RPC URLs ---
# Required in mainnet mode (no sensible default):
BASE_RPC_URL=
ETHEREUM_RPC_URL=
OPTIMISM_RPC_URL=
ARBITRUM_RPC_URL=
LINEA_RPC_URL=
UNICHAIN_RPC_URL=
WORLDCHAIN_RPC_URL=
SOLANA_RPC_URL=
STELLAR_RPC_URL=
# Required in testnet mode too (no sensible default except for legacy testnets):
ETHEREUM_SEPOLIA_RPC_URL=
OPTIMISM_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
LINEA_SEPOLIA_RPC_URL=
UNICHAIN_SEPOLIA_RPC_URL=
WORLDCHAIN_SEPOLIA_RPC_URL=
# Optional in testnet mode (public defaults embedded):
BASE_SEPOLIA_RPC_URL=
SOLANA_DEVNET_RPC_URL=
STELLAR_TESTNET_RPC_URL=

# --- Infrastructure ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fourzerotwomd
REDIS_URL=redis://localhost:6379
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=402md-settlement

# --- Tracing ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
