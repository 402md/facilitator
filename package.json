{
  "name": "402md",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "prettier --check",
      "eslint"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --check"
    ]
  },
  "devDependencies": {
    "turbo": "^2",
    "prettier": "^3",
    "eslint": "^9",
    "typescript": "^5",
    "husky": "^9",
    "lint-staged": "^15"
  }
}
